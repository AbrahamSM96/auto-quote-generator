{
  "name": "auto-quote-generator",
  "version": "0.1.0",
  "private": true,
  "workspaces": {
    "packages": [
      "rigs/eslint"
    ]
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "check": "bun run lint:fix && bun run format",
    "test": "bunx jest --coverage",
    "test:watch": "bunx jest --watch",
    "test:coverage": "bunx jest --coverage",
    "postinstall": "prisma generate",
    "migrate:quotations": "bun run scripts/migrate-quotations.ts",
    "dev:reset-master": "bun run scripts/reset-master-user.ts",
    "dev:check-users": "bun run scripts/check-users.ts",
    "dev:reset-folios": "bun run scripts/reset-folios.ts"
  },
  "dependencies": {
    "@eslint/compat": "1.3.2",
    "@hookform/resolvers": "^5.2.2",
    "@next/eslint-plugin-next": "16.1.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/client-runtime-utils": "^7.5.0",
    "@react-pdf/renderer": "^4.3.2",
    "@typescript-eslint/eslint-plugin": "8.53.0",
    "@typescript-eslint/parser": "8.53.0",
    "@typescript-eslint/typescript-estree": "8.53.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.12.1",
    "eslint-plugin-jsdoc": "50.6.17",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-oxlint": "1.41.0",
    "eslint-plugin-react-hooks": "7.0.0",
    "eslint-plugin-sort-destructure-keys": "2.0.0",
    "framer-motion": "^12.35.2",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "typescript-eslint": "8.53.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.2",
    "eslint-config-auto-quote-generator": "workspace:*",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react": "7.37.5",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.6",
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}

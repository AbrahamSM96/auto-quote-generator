{
  "jest.jestCommandLine": "bun run test",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "relay.rootDirectory": "packages",
  "relay.pathToConfig": "fragments/relay.config.js",
  "javascript.preferences.importModuleSpecifier": "relative",
  "typescript.preferences.importModuleSpecifier": "relative",
  "tailwindCSS.experimental.classRegex": [
    ["clsx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],
  "tailwindCSS.experimental.configFile": "packages/commons/src/themes/tudn/tudn-theme.css",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true
  },
  "editor.formatOnSave": true,
  "oxc.enable": true,
  "oxc.typeAware": true,
  "oxc.disableNestedConfig": false,
  "editor.formatOnSaveMode": "file",
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "oxc.path.oxlint": "./node_modules/.bin/oxlint",
  "oxc.path.oxfmt": "./node_modules/.bin/oxfmt",
  "prettier.enable": false,
  "biome.enabled": false,
  "eslint.format.enable": false,
  "tailwindCSS.classAttributes": [
    "class",
    "className",
    ".*class",
    ".*classes",
    ".*style",
    ".*styles"
  ]
}
